# mktemp - trap function - print the directory from where is executed

script_path () {
  NAMESCRIPT="$(basename "$0")" # show namescript executed dryncs
  DIRSCRIPT="$(dirname "$0")"   # show directory from where is executed dryncs
  PWDSCRIPT="$(pwd)"            # show the absolute path from where is executed
                                # NAMESCRIPT + DIRSCERIPT is needed for PWDSCRIPT
}

tempxall () {
  NAMESCRIPT="$(basename "$0")"
  DIRSCRIPT="$(dirname "$0")"
  PWDSCRIPT="$(pwd)"
  TMPDIR="$PWDSCRIPT/tmp"
  # Removing created temp files in unexpected bash exit
  trap 'rm -f -- "$TMPDIR"/*' EXIT
}

# Function print report

dlg_report_yesno () {
  "$DLG" --title "\Z0$1" \
    --backtitle "$3" --colors --stdout \
    --"$2" "$MSG_REPORT" 0 0
}

