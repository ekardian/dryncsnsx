dlg_msg () {
  "$DLG" --title "\Z0$1" \
    --backtitle "$3" --colors --ok-label "Cerrar" --stdout \
    --"$2" "$MSG" 0 0
}

dlg_fselect () {
  "$DLG" --title "\Z0$1" \
    --backtitle "$3" --colors --stdout \
    --"$2" "$FSELECT" "$FSHEIGHT" "$FSWIDTH" 
}

