        echo "" > "$Db_log"
        MSG=$(echo "\nLogs Limpiados.\n")
        dlg_msg "Configuración Base de Datos - Limpieza de Logs" "msgbox" "$BT_CONFIG"
        configs
        break
      ;;
      "Crear Respaldo")
        
        clear
        
        # Check if zip and unzip are installed
        [ $(which zip) ] && [ $(which unzip) ] ; if [ $(printf $?) = 1 ]; then 
        MSG=$(printf "\nLas aplicaciones: zip, unzip, no están instaladas.")
        dlg_msg "Configuración - Respaldo" "msgbox" "$BT_CONFIG"
        return 1
        fi
       
        # backup directories with : zip backup/<dryncsnsx-version-datestamp.zip> -qr db log orders reports
        printf "\n"
        printf " $SCRIPTNAME - $VERSION\n"
        printf " =================================================\n"
        printf "  Respaldo de dbs, logs, reports, orders, configs \n"
        printf " =================================================\n"
        printf "\n"
        printf " En progreso ...\n\n"

        TIMESTAMP=$(date +%Y-%m-%d_%T)
        ZIP_PATH=$(which zip)
        script_path
        cd "$PWDSCRIPT"
        "$ZIP_PATH" "$PWDSCRIPT/backup/$NAMESCRIPT-$VERSION-$TIMESTAMP.zip" -rq db log orders reports mdialog_conf
        sleep 3
        MSG=$(printf "%s" "\n Respaldo Completado en el directorio backup:\n\n Directorios respaldados:\n\n - db\n - log\n - orders\n - reports\n\n Archivos respaldados:\n\n mdialog_conf\n\n Para restaurar un respaldo use <Importar Respaldo>")
        dlg_msg "Configuración - Respaldo" "msgbox" "$BT_CONFIG"
        return
        break
      ;;
      "Importar Respaldo")
        
        clear
        
        # Check if zip and unzip are installed
        [ $(which zip) ] && [ $(which unzip) ] ; if [ $(printf $?) = 1 ]; then 
        MSG=$(printf "\nLas aplicaciones: zip, unzip, no están instaladas.")
        dlg_msg "Configuración - Respaldo" "msgbox" "$BT_CONFIG"
        return 1
        fi
       
        # Importing backup <dryncsnsx-version-datestamp.zip>
        
        UNZIP_PATH=$(which unzip)
        MSG=$(printf "\n\n Seleccione el archivo de respaldo comprmido (zip) para importar.\n\\nEsto sobreescribirá las carpetas:\n\n db, log, orders, reports\n\n y los archivos:\n\n mdialog_conf\n\n Para CANCELAR presione CTRL + ALC + C")
        dlg_msg "Configuración - Importar Archivo" "msgbox" "$BT_CONFIG"

        script_path
        BACKUP_FILER=$(FSELECT="$PWDSCRIPT/" \
        dlg_fselect "Configuración - Importar Archivo" "fselect" "$BT_CONFIG")
        Sexit=$?
        case $Sexit in
          0)
            clear
            printf "\n"
            printf " $SCRIPTNAME - $VERSION\n"
            printf " =================================================\n"
            printf "  Importando dbs, logs, reports, orders, configs \n"
            printf " =================================================\n"
            printf "\n"
            printf " En progreso ...\n\n"

            "$UNZIP_PATH" -d "$PWDSCRIPT/" -o "$BACKUP_FILER"
            printf "\n Espere un momento, completando la restauración ..."
            
            sleep 8
            clear

            MSG=$(printf "\n\n Respaldo Completado.\n\n El programa se cerrará tras cerrar este aviso para aplicar la configuración restaurada.\n\n Luego vuelva a abrir dryncsnsx.")
            dlg_msg "Configuración - Importar Archivo" "msgbox" "$BT_CONFIG"

            exit 
            ;;
          1|255)
            MSG=$(printf "\n Importación de Archivo Cancelado (Cod. $Sexit)")
            dlg_msg "Configuración - Importar Archivo" "msgbox" "$BT_CONFIG"
            return
           ;;
        esac
        
        break
      ;;
      "Volver al Menú Principal")
        break
      ;;
      "*")
        echo -e "Invalid choice"
      ;;
    esac
  done
}

