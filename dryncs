# Checking if mdialog_conf exists
verify_mdialog_conf () {
script_path
if [ ! -f "${PWDSCRIPT}/mdialog_conf" ]; then
  MSG="$(printf "\nEl archivo de configuración no existe. Genere uno con la plantilla de configuración de ejmplo:\n\ncp -v "${PWDSCRIPT}/mdialog_conf.inc" "${PWDSCRIPT}/mdialog_conf\n"")"
  dlg_msg "ERROR" "msgbox" "$BT_CONFIG"
  clear
  exit
fi
}

# Function for dump the log date errors

log_check () {
  ok_check="[OK]"
  err_check="[ERROR]"
}

aborted () {
  clear
  printf "\n"
  printf "%s\n" "$lin"
  printf "App Aborted. If you saw a bug, please report it to:\n"
  printf "https://github.com/ekardian/dryncsnsx/issues\n"
  printf "DONATION: https://github.com/ekardian/dryncsnsx#donation\n"
  printf "%s\n" "$lin"
  printf "\n"
  exit 1
}

userExit () {
  clear
  printf "\n"
  printf "%s\n" "$lin"
  printf "    dryncsnsx has closed successfully  \n"
  printf "https://github.com/ekardian/dryncsnsx/issues\n"
  printf "DONATION: https://github.com/ekardian/dryncsnsx#donation\n"
  printf "%s\n" "$lin"
  printf "\n"
  exit 0
}

