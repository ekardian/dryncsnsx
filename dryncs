######################################

db_backup_before_updating () {
  "$DLG" --title "\Z0Actualizando Base de Datos" \
    --backtitle "$BT_CONFIG" --colors --yes-label "Continuar" --no-label "Cancelar" --stdout \
    --yesno "\nAdvertencia. Realice una copia de la base de datos que va a sobreescribir\n\nSi no lo requiere presione Continuar.\n\n" 0 0
  Sexit=$?
  if [ "$Sexit" = 1 ] || [ "$Sexit" = 255 ]; then
    main 
  fi
}

configs () {
clear
printf "$SCRIPTNAME - $VERSION\n"
printf "==============================\n"
printf " Actualizar Dbs e información \n"
printf "==============================\n"
printf "<- Menú anterior 'Menú Principal'\n"
printf "\n"
  COLUMNS=12
  local PS3="Opción: "
  printf "Escoja una Opción\n"
  select choice in "Update Películas" "Update Música" "Update Juegos"  "Update Apps" "Update Libros"  "Update Comics" "Dispositivos Montados y Tamaño" "Ver el mdialog_conf" "Configuración" "Vaciar Base de Datos" "Limpiar pedidos" "Limpiar Logs" "Crear Respaldo" "Importar Respaldo" "Volver al Menú Principal"; do
    case $choice in
      "Update Películas")

        db_backup_before_updating

        clear
        printf "\n"
        printf "$SCRIPTNAME - $VERSION\n"
        printf "==============================\n"
        printf "    Llenando Dbs de Videos \n"
        printf "==============================\n"
        printf "\n" 

        printf "En progreso ...\n\n"
        sleep 3

        printf "" > "$fallrepos"    # x copy path
        printf "" > "$sfallrepos"   # x print size video files 
        printf "" > "$xfallrepos"   # x module search

        # for more paths add to mdialog_conf and fill the f_path array like
        # f_path=("$fsourcepath1" "fsourcepath2" "...")

        f_path=("$fsourcepath1" "$fsourcepath2" "$fsourcepath3" "$fsourcepath4" "$fsourcepath5" "$fsourcepath6" "$fsourcepath7" "$fsourcepath8" "$fsourcepath9" "$fsourcepath10")
        
        log_check
        
        let i=1
        for dir in "${f_path[@]}"; do
          i_f=$((i++))
          if [ -d "$dir" ]; then
            find "$dir" -type f >> "$fallrepos"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Video ruta $i_f: actualizada con fallrepos" >> "$Db_log"
            find "$dir" -type f -print0 | du --files0-from=- -k >> "$sfallrepos"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Video ruta $i_f: actualizada con sfallrepos" >> "$Db_log"
            find "$dir" -type f -printf "%s - %f\n" | numfmt --to=iec >> "$xfallrepos"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Video ruta $i_f: actualizada con xfallrepos" >> "$Db_log"
          else
            printf "%s %s - %s\n" "$err_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Video ruta $i_f: no está configurada" >> "$Db_log"
          fi
        done

        MSG=$(cat "$Db_log")
        dlg_msg "Base de Datos - Log general" "msgbox" "$BT_MUSIC"

        configs
        break
      ;;
      "Update Música")

        db_backup_before_updating
        
        clear
        printf "\n"
        printf "$SCRIPTNAME - $VERSION\n"
        printf "==============================i\n"
        printf "    Llenando Dbs de Música \n"
        printf "==============================\n"
        printf "\n"

        printf "En progreso ...\n\n"
        sleep 3

        # for more paths add to mdialog_conf and fill the s_path array like
        # s_path=("$msourcepath1" "msourcepath2" "...")

        printf "" > "$mallrepos"    # x copy path
        printf "" > "$smallrepos"   # x sum items, reports
        printf "" > "$xmallrepos"   # x search Albums + tracks numbers
        printf "" > "$xmallrepos2"  # x search Tracks with file size + LCT Code
        printf "" > "$pmallrepos3"  # x db temp x LCT Codes > $Pmlct
                                  #   "$pmlct" Music LCT Codes 

        m_path=("$msourcepath1" "$msourcepath2" "$msourcepath3")
        
        log_check
        
        let i=1
        for dir in "${m_path[@]}"; do
          i_m=$((i++))
          if [ -d "$dir" ]; then
            find "$dir" -type d >> "$mallrepos"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Audio ruta $i_m: actualizada con mallrepos" >> "$Db_log"
            find "$dir" -maxdepth 0 -type d -exec du -k {} \; >> "$smallrepos"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Audio ruta $i_m: actualizada con smallrepos" >> "$Db_log"
            find "$dir" -type d -print0 | xargs -0 -IDIR sh -c 'echo "$(basename "DIR"): $(ls "DIR" | wc -l) tracks"' | sort >> "$xmallrepos"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Audio ruta $i_m: actualizada con xmallrepos" >> "$Db_log"
            cd "$dir"
            find -type f -printf "-%s -%p\n" | numfmt --invalid=ignore --to=iec >> "$pmallrepos3"
            printf "%s %s - %s\n" "$ok_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Audio ruta $i_m: actualizada con pmallrepos3" >> "$Db_log"
          else
            printf "%s %s - %s\n" "$err_check" "$(date +%Y-%m-%d-%Hh:%Mm)" "Audio ruta $i_m: no está configurada" >> "$Db_log"
          fi
        done

        script_path
